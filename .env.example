# Copy to .env and adjust. All keys map to config/settings.py:Settings.

PROJECT_NAME=fastAPI_api
DEBUG=true
SECRET_KEY=change-me-in-production

HOST=127.0.0.1
PORT=8000

# --- Databricks (the only datastore) ---------------------------------------
# From your SQL warehouse's "Connection details" tab.
DATABRICKS_SERVER_HOSTNAME=dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=default

# Escape hatch: a full SQLAlchemy URL that overrides the five settings above.
# DATABASE_URL=databricks://token:dapi...@host?http_path=...&catalog=main&schema=default

# Connection pool. Warehouse round-trips are slow, so keep connections warm.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=3600
DB_ECHO=false

# --- Admin dashboard (fastadmin — no Redis, JWT-cookie sessions) -----------
ADMIN_PREFIX=admin
ADMIN_SITE_NAME=fastAPI_api Admin
ADMIN_USER_MODEL=AdminUser
ADMIN_USER_MODEL_USERNAME_FIELD=username
# Secret for signing the admin session cookie (defaults to SECRET_KEY).
ADMIN_SECRET_KEY=change-me-in-production
# Superuser auto-created on startup (change for production!).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_AUTO_CREATE=true

# --- Audit log -------------------------------------------------------------
# Allow audit entries to be edited (PATCH) or deleted (DELETE) over the API.
# Leave false in production: an audit trail that can be rewritten through an
# endpoint is hard to defend. Creating and reading entries is unaffected.
AUDIT_LOG_ALLOW_MUTATION=false

LOG_LEVEL=DEBUG
