# Copy to .env and adjust. All keys map to config/settings.py:Settings.

PROJECT_NAME=fastAPI_api
DEBUG=true
SECRET_KEY=change-me-in-production

HOST=127.0.0.1
PORT=8000

# Tortoise ORM connection URL (sqlite / postgres / mysql).
# DATABASE_URL=postgres://user:pass@localhost:5432/app
DATABASE_URL=sqlite://db.sqlite3

# fastapi-admin dashboard
# Redis is optional: if unreachable the admin falls back to in-memory fakeredis.
REDIS_URL=redis://localhost:6379/0
ADMIN_PATH=/admin
ADMIN_TITLE=fastAPI_api Admin
# Superuser auto-created on startup (change for production!).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_AUTO_CREATE=true

LOG_LEVEL=DEBUG
